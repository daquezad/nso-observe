# =============================================================================
# NSO Docker Project .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials & Environment
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# NEDs (large binaries, user-provided)
# -----------------------------------------------------------------------------
neds/*
!neds/.gitkeep

# -----------------------------------------------------------------------------
# NSO Images (large tarballs & binaries, user-provided)
# -----------------------------------------------------------------------------
images/*
!images/.gitkeep
!images/Dockerfile.prod
!images/cisco_x509_verify_release.py3

# -----------------------------------------------------------------------------
# NSO Packages (large tarballs, user-provided; extracted dirs)
# -----------------------------------------------------------------------------
packages/*
!packages/.gitkeep

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
packages-compiled/

# -----------------------------------------------------------------------------
# Legacy / Backup
# -----------------------------------------------------------------------------
nso-docker-old/

# -----------------------------------------------------------------------------
# Project Methodology Tooling
# -----------------------------------------------------------------------------
_bmad/
_bmad-output/

# -----------------------------------------------------------------------------
# HA Raft TLS Certificates (generated, contain private keys)
# -----------------------------------------------------------------------------
certs/

# -----------------------------------------------------------------------------
# OS & IDE
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.cursor/
.vscode/
.idea/
*.swp
*.swo
*~
